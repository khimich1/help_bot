# --- LLM для ReAct-агента (openai | deepseek) ---
LLM_PROVIDER=deepseek

# DeepSeek (официальный API — ключ с platform.deepseek.com)
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# OpenAI (альтернатива для агента + обязателен для Whisper при LLM_PROVIDER=deepseek)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=111111111,222222222

# БД и голос
DATABASE_URL=sqlite:///./data/studio.db
WHISPER_MODEL=whisper-1

# Project knowledge (RAG)
# openai — OpenAI API; local — sentence-transformers (без геоблока)
EMBEDDING_PROVIDER=openai
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
LOCAL_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
CHROMA_PERSIST_DIR=./data/chroma
KNOWLEDGE_TOP_K=5

# Web search (DuckDuckGo, API key not required)
WEB_SEARCH_PROVIDER=duckduckgo
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_REGION=ru-ru
