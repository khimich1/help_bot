# --- LLM для ReAct-агента (openai | deepseek) ---
LLM_PROVIDER=deepseek

# DeepSeek (официальный API — ключ с platform.deepseek.com)
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# OpenAI (альтернатива для агента + обязателен для Whisper при LLM_PROVIDER=deepseek)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=111111111,222222222

# БД и голос
DATABASE_URL=sqlite:///./data/studio.db
WHISPER_MODEL=whisper-1
